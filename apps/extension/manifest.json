{
  "manifest_version": 3,
  "name": "RusType",
  "version": "0.6.13",
  "description": "Russian writing assistant for Vietnamese.",
  "icons": {
    "16": "assets/icons/rutype_icon16.png",
    "32": "assets/icons/rutype_icon32.png",
    "48": "assets/icons/rutype_icon48.png",
    "128": "assets/icons/rutype_icon128.png"
  },
  "permissions": ["storage", "activeTab", "webNavigation", "contextMenus"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "src/background/service-worker.js"
  },
  "action": {
    "default_title": "RusType",
    "default_popup": "src/popup/popup.html",
    "default_icon": {
      "16": "assets/icons/rutype_icon16.png",
      "32": "assets/icons/rutype_icon32.png",
      "48": "assets/icons/rutype_icon48.png",
      "128": "assets/icons/rutype_icon128.png"
    }
  },
  "options_page": "src/options/options.html",
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "exclude_matches": [
        "*://youtube.com/*",
        "*://*.youtube.com/*"
      ],
      "js": ["src/content/autocomplete-dictionary.generated.js", "src/content/autocomplete-engine.js", "src/content/content-script.js"],
      "run_at": "document_idle",
      "all_frames": true,
      "match_about_blank": true
    }
  ]
}
